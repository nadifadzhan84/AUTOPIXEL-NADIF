# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------

# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Tip: after the bot starts, run /doctor in Telegram to verify your setup

# Optional: Header media shown on /start
# Supports a local file path, direct image URL, GIF URL, or MP4 URL
BOT_HEADER_MEDIA_URL=


# ---------------------------------------------------------------------------
# Device profile
# ---------------------------------------------------------------------------

# Optional: which Pixel build the bot should simulate
# Available presets (only devices eligible for the Google One AI Premium 2 TB
# 12-month trial are listed):
#   pixel_10_pro        Pixel 10 Pro on Android 16 (default)
#   pixel_10_pro_xl     Pixel 10 Pro XL on Android 16
#   pixel_10_pro_fold   Pixel 10 Pro Fold on Android 16
#   pixel_9_pro         Pixel 9 Pro on Android 16
#   pixel_9_pro_xl      Pixel 9 Pro XL on Android 16
#   pixel_9_pro_fold    Pixel 9 Pro Fold on Android 16
# Leave empty to use the default Pixel 10 Pro / Android 16 profile.
DEVICE_PROFILE=


# ---------------------------------------------------------------------------
# Browser
# ---------------------------------------------------------------------------

# Optional: Explicit browser binary path if auto-detection fails
# Example (Windows): C:\Program Files\Google\Chrome\Application\chrome.exe
# Example (Linux): /usr/bin/google-chrome
CHROME_BIN=

# Optional: Explicit chromedriver path if needed
# Example (Windows): C:\tools\chromedriver.exe
# Example (Linux): /usr/bin/chromedriver
CHROMEDRIVER_PATH=

# Optional: Force a Chrome version string if auto-detection is wrong
# Example: 146.0.7680.165
CHROME_VERSION=

# Temporary test-only bypass for Chrome privacy/certificate interstitials.
# Keep this at 0 for normal use; set to 1 only when a proxy MITM certificate
# is expected and you explicitly want Chrome to continue anyway.
BROWSER_IGNORE_CERT_ERRORS=0

# Optional: let AutoPixel try audio captcha solving before it falls back
# to manual verification in Chrome. Requires a valid Wit.ai server token.
GOOGLE_CAPTCHA_AUTO_SOLVE=1
GOOGLE_CAPTCHA_MAX_AUDIO_ATTEMPTS=3
WIT_AI_TOKEN=
WIT_AI_SPEECH_API_VERSION=20240304
WIT_AI_TIMEOUT_SECONDS=45


# ---------------------------------------------------------------------------
# Fallback geolocation / timezone
# ---------------------------------------------------------------------------

# Used only when route-based proxy/IP detection is unavailable
# Tip: the /ip command now shows .env-ready emulation values for the active route
# Tip: if you want a fixed fallback, copy the timezone/GPS values shown by /ip
# into the four EMULATION_* fields below
EMULATION_TIMEZONE_ID=America/Los_Angeles
EMULATION_GEO_LATITUDE=37.3861
EMULATION_GEO_LONGITUDE=-122.0839
EMULATION_GEO_ACCURACY=100


# ---------------------------------------------------------------------------
# Proxy pool
# ---------------------------------------------------------------------------

# Set to 1 to enable proxy mode by default, or 0 for direct mode
# Important: leaving PROXY_FILE_PATH empty does NOT disable proxies
# It falls back to the default project file: proxies.txt
# If you want direct/local IP on startup, set PROXY_ENABLED=0
PROXY_ENABLED=1

# Leave empty to use the default project file: proxies.txt
PROXY_FILE_PATH=

# Cooldown after a single proxy transport failure
PROXY_FAILURE_COOLDOWN_SECONDS=90

# Quarantine duration after repeated failures
PROXY_QUARANTINE_SECONDS=300

# Number of failures before a proxy enters quarantine
PROXY_QUARANTINE_THRESHOLD=3

# Enable or disable HTTP precheck before launching Chrome
PROXY_PRECHECK_ENABLED=1
PROXY_PRECHECK_TIMEOUT_SECONDS=12

# Set to 0 to ignore self-signed/intercepted TLS chains during proxy-only
# diagnostics such as /ip and the Google sign-in precheck. Chrome still keeps
# its own certificate handling for the real login flow.
PROXY_DIAGNOSTICS_VERIFY_SSL=0


# ---------------------------------------------------------------------------
# Retry behavior
# ---------------------------------------------------------------------------

# Set to 1 to mint a fresh device profile on retry, or 0 to reuse the same one
REGENERATE_DEVICE_ON_RETRY=1
